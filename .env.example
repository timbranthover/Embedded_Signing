# ─── DocuSign OAuth ─────────────────────────────────────────────────────────
VITE_DS_CLIENT_ID=5474e846-98a1-47b7-b9bd-b7f31c3fad9c
VITE_DS_AUTH_BASE=https://account-d.docusign.com
VITE_DS_SCOPES=signature cors openid profile email

# ─── Template ────────────────────────────────────────────────────────────────
VITE_DS_TEMPLATE_ID=d880d558-b959-4cc8-a4c1-2aff259c829f

# IMPORTANT: Set this to the role name of the signer in your template.
# Find it in DocuSign → Templates → [your template] → Edit → Recipients → Role Name
VITE_DS_TEMPLATE_ROLE_NAME=Signer

# Unique ID for embedded signing (any non-empty string)
VITE_DS_CLIENT_USER_ID=1000

# ─── API mode ────────────────────────────────────────────────────────────────
# "direct"  — browser calls DocuSign directly (requires CORS origins in DocuSign)
# "worker"  — use Cloudflare Worker proxy (see worker/README.md)
VITE_DS_API_MODE=direct
VITE_DS_WORKER_URL=https://YOURWORKER.example.workers.dev
